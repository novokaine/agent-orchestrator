# Database
MONGO_ROOT_USER=agent_admin
MONGO_ROOT_PASS=ChangeMe123StrongPassword

# Redis
REDIS_PASSWORD=RedisSecurePass456!

# Security
SECRET_KEY=your-secret-key-here-change-in-production-$(openssl rand -hex 32)

# LLM Configuration
# LLM_MODEL=llama3.1:70b-instruct-q4_K_M
# Alternative models for T630:
# - llama3.1:8b (faster, less capable)
# - codellama:34b (better at code)
# - deepseek-coder:33b (excellent for code)
# - mixtral:8x7b (good balance)

# API Keys (optional fallbacks)
OPENAI_API_KEY=

# Agent Settings
AGENT_LOG_LEVEL=INFO
MAX_ITERATIONS=10
TEMPERATURE=0.7

# Project paths
PROJECTS_ROOT=./projects
LLM_MODEL=codellama:34b